# ── Database (Supabase pooler) ────────────────────────────────────────────────
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Person 3's celery_app.py uses REDIS_URL for both broker and backend
REDIS_URL=redis://localhost:6379/0

# ── AI Agent (Person 2) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Satellite pipeline (Person 3) ─────────────────────────────────────────────
# OAuth credentials from https://dataspace.copernicus.eu → User Settings → OAuth clients
CDSE_CLIENT_ID=your-client-id
CDSE_CLIENT_SECRET=your-client-secret
# Set to False to use real Sentinel-2 data (requires CDSE credentials above)
PIPELINE_USE_SYNTHETIC=True

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=*
