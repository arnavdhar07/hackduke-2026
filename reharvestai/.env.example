# ── Database (Supabase) ───────────────────────────────────────────────────────
# Direct connection URI — used by Celery workers and Alembic migrations.
# Get your PASSWORD from: Supabase dashboard → Settings → Database → Database password
DATABASE_URL=postgresql+asyncpg://postgres.kdsgnodshdzulpupvlka:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Supabase project credentials
SUPABASE_URL=https://kdsgnodshdzulpupvlka.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imtkc2dub2RzaGR6dWxwdXB2bGthIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQxMTE1NTcsImV4cCI6MjA4OTY4NzU1N30.khvB6p_Eo_sSqMWYXeCFyDn2aTk84Q5IPazLvz_Yauo
# Get SUPABASE_SERVICE_ROLE_KEY from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Copernicus Data Space Ecosystem (CDSE) ────────────────────────────────────
# Register free at https://dataspace.copernicus.eu/
# If empty, the pipeline will use synthetic (mock) imagery instead.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ── SAM3 Segmentation ─────────────────────────────────────────────────────────
# Download checkpoint from the SAM3 release page and place at this path.
# Mount this path into the worker container via docker-compose volumes.
SAM3_CHECKPOINT_PATH=/models/sam3_vit_h.pth
SAM3_MODEL_TYPE=vit_h

# ── Pipeline behaviour ────────────────────────────────────────────────────────
# Maximum cloud cover percentage for Sentinel-2 scene selection (0–100)
SENTINEL_MAX_CLOUD_PCT=30.0
# How many days back to search for imagery
SENTINEL_LOOKBACK_DAYS=10
# Set to true to skip CDSE entirely and always use synthetic imagery
PIPELINE_USE_SYNTHETIC=false

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-in-production
LOG_LEVEL=INFO
