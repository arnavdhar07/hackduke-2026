# ── Database (Supabase) ──────────────────────────────────────────────────────
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.kdsgnodshdzulpupvlka.supabase.co:5432/postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Copernicus Hub (Sentinel-2 real data) ────────────────────────────────────
# Register at: https://dataspace.copernicus.eu/
COPERNICUS_USER=your-username
COPERNICUS_PASSWORD=your-password

# ── Satellite pipeline mode ──────────────────────────────────────────────────
# Set to False to use real Sentinel-2 data (requires COPERNICUS_* above)
USE_MOCK_SATELLITE=True

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=*
